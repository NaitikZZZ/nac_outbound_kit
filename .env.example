# Xoxoday Outbound Kit - API Keys
# Copy this file to .env and fill in your personal keys.
# Never commit .env to git (it's in .gitignore).

# Smartlead - Settings > API Keys in Smartlead dashboard
SMARTLEAD_API_KEY=your_smartlead_key_here

# Apollo - Settings > Integrations > API in Apollo
APOLLO_API_KEY=your_apollo_key_here

# ZeroBounce - My Account > API
ZEROBOUNCE_API_KEY=your_zerobounce_key_here

# HeyReach - Settings > API (if not using MCP connector)
HEYREACH_API_KEY=your_heyreach_key_here

# Clay - Workspace Settings > API (only if running Clay waterfalls programmatically)
CLAY_API_KEY=your_clay_key_here

# Optional: HubSpot Record ID used as primary key on HubSpot imports
HUBSPOT_RECORD_ID=your_hubspot_record_id_here
